#!/bin/bash
# boot — venv bootstrap wrapper for permission-guard hook
# If venv is missing, output "ask" with setup instruction instead of failing.
VENV="${CLAUDE_PLUGIN_ROOT}/.venv/bin/python3"
if [ ! -f "$VENV" ]; then
  echo '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"ask","permissionDecisionReason":"permission-guard: venv not found. Run /permission-guard:setup"}}'
  exit 0
fi
exec "$VENV" "${CLAUDE_PLUGIN_ROOT}/scripts/permission-fallback"
