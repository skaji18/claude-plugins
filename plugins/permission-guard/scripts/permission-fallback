#!/usr/bin/env python3
"""
.claude/hooks/permission-fallback

PermissionRequest fallback hook (Python reimplementation)
Automatically approves PROJECT_DIR-scoped execution (+ allowed_dirs_extra) with 8-phase validation.
New Phase 7B2: Subcommand rejection for destructive operations.
"""

import sys
import json
import re
import os
from pathlib import PurePosixPath

import yaml


class RejectException(Exception):
    def __init__(self, reason):
        self.reason = reason


class AllowException(Exception):
    pass

# --- Configuration ---
def _detect_project_dir():
    """Detect project directory. Works in both Plugin and inline modes."""
    # Priority 1: CLAUDE_PROJECT_DIR (Claude Code always sets this for hooks)
    env_dir = os.environ.get("CLAUDE_PROJECT_DIR")
    if env_dir:
        return os.path.abspath(env_dir)

    # Priority 2: __file__ relative (inline mode: .claude/hooks/permission-fallback)
    file_based = os.path.abspath(os.path.join(os.path.dirname(__file__), "../.."))
    if os.path.isdir(os.path.join(file_based, ".claude")):
        return file_based

    # Priority 3: cwd
    return os.path.abspath(os.getcwd())

PROJECT_DIR = _detect_project_dir()
DEBUG = os.getenv("PERMISSION_DEBUG", "0") == "1"


def allow():
    raise AllowException()


def reject(reason="unknown"):
    raise RejectException(reason)


def load_config():
    """Load permission-config.yaml with 4-layer merge (Plugin + Project + Local)."""
    plugin_root = os.environ.get("CLAUDE_PLUGIN_ROOT", "")

    if plugin_root:
        # Plugin mode: base config is in plugin's config/ directory
        base_config_path = os.path.join(plugin_root, "config", "permission-config.yaml")
    else:
        # Inline mode: config is adjacent to this script (.claude/hooks/)
        base_config_path = os.path.join(os.path.dirname(__file__), "permission-config.yaml")

    # Layer 2: Project-level config (NEW)
    project_config_path = os.path.join(PROJECT_DIR, ".claude", "permission-config.yaml")
    # Layer 3: Local overlay (unchanged behavior)
    local_path = os.path.join(PROJECT_DIR, "local", "hooks", "permission-config.yaml")

    # Security floor: items that can NEVER be removed
    FLOOR_ALWAYS_ASK = {"sudo", "su", "rm", "rmdir"}
    FLOOR_SUBCOMMAND_ASK = {
        "git:push", "git:reset:--hard", "gh:pr:merge",
    }

    # FROZEN: interpreters key cannot be overridden (Fix 1)
    FROZEN_KEYS = {"interpreters"}

    # Hardcoded defaults (unchanged from current code)
    default_config = {
        "interpreters": {
            "python3": {
                "safe_flags": ["u", "B", "s", "S", "v", "b", "q", "O", "I", "E", "P", "R"],
                "dangerous_flags": ["c", "e", "m"],
                "dangerous_long_flags": ["--command", "--eval"]
            },
            "bash": {
                "safe_flags": ["n", "x", "e", "u", "v", "E", "f", "r"],
                "dangerous_flags": ["c", "i"],
                "dangerous_long_flags": ["--init-file", "--rcfile"]
            },
            "sh": {
                "safe_flags": ["x", "e", "u", "v", "E", "f", "r"],
                "dangerous_flags": ["c", "i"],
                "dangerous_long_flags": ["--init-file", "--rcfile"]
            },
            "node": {
                "safe_flags": ["v"],
                "dangerous_flags": ["e", "p"],
                "dangerous_long_flags": ["--eval", "--print", "--require", "--input-type"]
            },
            "perl": {
                "safe_flags": ["w", "T", "c", "v"],
                "dangerous_flags": ["e", "E"],
                "dangerous_long_flags": []
            },
            "ruby": {
                "safe_flags": ["w", "d", "v"],
                "dangerous_flags": ["e"],
                "dangerous_long_flags": ["--eval"]
            },
            "php": {
                "safe_flags": ["v", "i", "m"],
                "dangerous_flags": ["r"],
                "dangerous_long_flags": ["--run"]
            }
        },
        "interpreters_extra": {},
        "always_ask": [
            "curl", "wget", "ssh", "scp", "rsync", "nc",
            "sudo", "su",
            "eval", "exec", "xargs", "env", "nohup", "timeout",
            "busybox", "screen", "tmux", "script",
            "pip", "pip3", "npm", "apt", "apt-get",
            "rm", "rmdir", "mv", "cp",
            "python", "python2",                          # F-003
            "dash", "zsh", "ksh", "fish", "csh", "tcsh",  # F-004
            "command",                                      # F-010
            "find", "chmod", "chown"                        # NEW-6
        ],
        "known_safe": [
            "ls", "cat", "head", "tail", "wc", "sort", "uniq", "cut", "paste",
            "tr", "tee", "diff", "cmp", "comm",
            "grep", "rg", "fd", "fzf", "ag", "ack",
            "sed", "awk", "jq", "yq",
            "date", "cal", "echo", "printf", "true", "false", "test", "[",
            "basename", "dirname", "realpath", "readlink",
            "stat", "file", "which", "type",
            "whoami", "id", "uname", "hostname", "pwd",
            "printenv",
            "tree", "du", "df", "free", "uptime",
            "less", "more",
            "xxd", "od", "hexdump",
            "md5sum", "sha256sum", "base64",
            "column", "expand", "unexpand", "fold", "fmt", "nl", "rev",
            "seq", "yes",
            "git", "gh",
            "make", "cargo", "gcc", "g++", "cc", "c++",
            "go", "rustc", "javac", "java",
            "docker", "kubectl",
            "npx", "yarn", "pnpm",
        ],
        "known_safe_extra": [],
        "subcommand_rules": {
            "git": {
                "allow": [
                    "status", "log", "diff", "show", "branch", "tag", "remote",
                    "stash", "describe", "shortlog", "blame", "bisect",
                    "reflog", "rev-parse", "rev-list", "ls-files", "ls-tree",
                    "ls-remote", "cat-file", "for-each-ref", "name-rev",
                    "config", "var", "help", "version",
                    "count-objects", "fsck", "verify-pack",
                    "notes", "grep", "log", "whatchanged",
                    "add", "commit", "fetch", "clone", "init",
                    "mv", "rm", "switch", "worktree",
                    "cherry-pick", "apply", "am",
                    "submodule", "sparse-checkout",
                    "archive", "bundle",
                ],
                "ask": [
                    "push", "pull", "merge", "rebase", "reset",
                    "checkout:.", "restore:.",
                    "clean",
                    "stash:drop", "stash:clear",
                    "branch:-D", "tag:-d",
                    "filter-branch",
                    "gc",
                ],
                "default_action": "ask"
            },
            "docker": {
                "allow": [
                    "ps", "images", "logs", "inspect", "info", "version",
                    "stats", "top", "port", "diff", "history",
                    "network:ls", "network:inspect",
                    "volume:ls", "volume:inspect",
                    "compose:ps", "compose:logs", "compose:config",
                ],
                "ask": [
                    "run", "exec", "rm", "rmi", "stop", "kill",
                    "build", "push", "pull",
                    "system:prune",
                    "compose:up", "compose:down", "compose:build",
                ],
                "default_action": "ask"
            },
            "gh": {
                "allow": [
                    "pr:list", "pr:view", "pr:status", "pr:checks", "pr:diff",
                    "issue:list", "issue:view", "issue:status",
                    "repo:list", "repo:view",
                    "run:list", "run:view",
                    "release:list", "release:view",
                    "api",
                    "auth:status",
                    "status",
                ],
                "ask": [
                    "pr:merge", "pr:close", "pr:reopen",
                    "issue:close", "issue:delete",
                    "repo:delete", "repo:archive",
                    "release:delete", "release:create",
                    "run:cancel",
                ],
                "default_action": "ask"
            }
        },
        "subcommand_ask": [
            "git:push",
            "git:clean",
            "git:reset:--hard",
            "git:checkout:.",
            "git:restore:.",
            "gh:pr:merge",
            "gh:repo:delete",
            "gh:repo:archive",
            "gh:release:delete",
            "git:stash:drop",       # NEW-5
            "git:stash:clear",      # NEW-5
            "git:rebase",           # NEW-5
            "git:branch:-D",        # NEW-5
            "git:tag:-d",           # NEW-5
            "git:filter-branch"     # NEW-5
        ],
        "allowed_dirs_extra": []
    }

    # Layer 1: Load base config (overrides defaults)
    if os.path.exists(base_config_path):
        try:
            with open(base_config_path, 'r') as f:
                user_config = yaml.safe_load(f)
                if user_config:
                    for key in user_config:
                        default_config[key] = user_config[key]
        except (Exception) as e:
            if DEBUG:
                print(f"Config load failed: {e}, using defaults", file=sys.stderr)
            reject("config_parse_error")

    # Layer 2: Merge project-level config (if exists)
    if os.path.exists(project_config_path):
        try:
            with open(project_config_path, 'r') as f:
                project_conf = yaml.safe_load(f)
        except (Exception) as e:
            if DEBUG:
                print(f"Project config load failed: {e}, ignoring overlay", file=sys.stderr)
            return default_config

        if not isinstance(project_conf, dict):
            if DEBUG:
                print(f"Project config is not a YAML mapping, ignoring overlay", file=sys.stderr)
            return default_config

        # Skip frozen keys entirely
        for key in FROZEN_KEYS:
            if key in project_conf:
                if DEBUG:
                    print(
                        f"WARNING: '{key}' is frozen, cannot be overridden. Ignoring.",
                        file=sys.stderr,
                    )

        # always_ask: union + floor enforced + null safety
        if 'always_ask' in project_conf:
            merged_set = set(default_config.get('always_ask', []))
            proj_value = project_conf['always_ask']
            if isinstance(proj_value, list):
                merged_set |= set(proj_value)
            elif proj_value is not None:
                if DEBUG:
                    print(
                        f"WARNING: always_ask expected array, got "
                        f"{type(proj_value).__name__}. Ignoring.",
                        file=sys.stderr,
                    )
            merged_set |= FLOOR_ALWAYS_ASK
            default_config['always_ask'] = sorted(merged_set)

        # subcommand_ask: union + floor enforced + null safety
        if 'subcommand_ask' in project_conf:
            merged_set = set(default_config.get('subcommand_ask', []))
            proj_value = project_conf['subcommand_ask']
            if isinstance(proj_value, list):
                merged_set |= set(proj_value)
            elif proj_value is not None:
                if DEBUG:
                    print(
                        f"WARNING: subcommand_ask expected array, got "
                        f"{type(proj_value).__name__}. Ignoring.",
                        file=sys.stderr,
                    )
            merged_set |= FLOOR_SUBCOMMAND_ASK
            default_config['subcommand_ask'] = sorted(merged_set)

        # allowed_dirs_extra: union (append-only) + null safety
        if 'allowed_dirs_extra' in project_conf:
            base_dirs = set(default_config.get('allowed_dirs_extra', []))
            proj_value = project_conf['allowed_dirs_extra']
            if isinstance(proj_value, list):
                base_dirs |= set(proj_value)
            elif proj_value is not None:
                if DEBUG:
                    print(
                        f"WARNING: allowed_dirs_extra expected array, got "
                        f"{type(proj_value).__name__}. Ignoring.",
                        file=sys.stderr,
                    )
            default_config['allowed_dirs_extra'] = sorted(base_dirs)

        # known_safe_extra: union (append-only, cannot remove from base known_safe)
        if 'known_safe_extra' in project_conf:
            base_extra = set(default_config.get('known_safe_extra', []))
            proj_value = project_conf['known_safe_extra']
            if isinstance(proj_value, list):
                base_extra |= set(proj_value)
            elif proj_value is not None:
                if DEBUG:
                    print(
                        f"WARNING: known_safe_extra expected array, got "
                        f"{type(proj_value).__name__}. Ignoring.",
                        file=sys.stderr,
                    )
            default_config['known_safe_extra'] = sorted(base_extra)

        # interpreters_extra: merge (additive only, cannot override base interpreters)
        if 'interpreters_extra' in project_conf:
            proj_value = project_conf['interpreters_extra']
            if isinstance(proj_value, dict):
                base_extra = default_config.get('interpreters_extra', {})
                for k, v in proj_value.items():
                    if isinstance(v, dict):
                        base_extra[k] = v
                default_config['interpreters_extra'] = base_extra
            elif proj_value is not None:
                if DEBUG:
                    print(
                        f"WARNING: interpreters_extra expected mapping, got "
                        f"{type(proj_value).__name__}. Ignoring.",
                        file=sys.stderr,
                    )

    # Layer 3: Merge local overlay (if exists)
    if os.path.exists(local_path):
        try:
            with open(local_path, 'r') as f:
                local = yaml.safe_load(f)
        except (Exception) as e:
            if DEBUG:
                print(f"Local config load failed: {e}, ignoring overlay", file=sys.stderr)
            return default_config

        if not isinstance(local, dict):
            if DEBUG:
                print(f"Local config is not a YAML mapping, ignoring overlay", file=sys.stderr)
            return default_config

        # Fix 1: Skip frozen keys entirely
        for key in FROZEN_KEYS:
            if key in local:
                if DEBUG:
                    print(
                        f"WARNING: '{key}' is frozen, cannot be overridden. Ignoring.",
                        file=sys.stderr,
                    )

        # always_ask: union + floor enforced + null safety (Fix 3)
        if 'always_ask' in local:
            merged_set = set(default_config.get('always_ask', []))
            local_value = local['always_ask']
            if isinstance(local_value, list):
                merged_set |= set(local_value)
            elif local_value is not None:
                if DEBUG:
                    print(
                        f"WARNING: always_ask expected array, got "
                        f"{type(local_value).__name__}. Ignoring.",
                        file=sys.stderr,
                    )
            # null is treated as empty (no additions, no crash)
            merged_set |= FLOOR_ALWAYS_ASK
            default_config['always_ask'] = sorted(merged_set)

        # subcommand_ask: union + floor enforced + null safety (Fix 3)
        if 'subcommand_ask' in local:
            merged_set = set(default_config.get('subcommand_ask', []))
            local_value = local['subcommand_ask']
            if isinstance(local_value, list):
                merged_set |= set(local_value)
            elif local_value is not None:
                if DEBUG:
                    print(
                        f"WARNING: subcommand_ask expected array, got "
                        f"{type(local_value).__name__}. Ignoring.",
                        file=sys.stderr,
                    )
            merged_set |= FLOOR_SUBCOMMAND_ASK
            default_config['subcommand_ask'] = sorted(merged_set)

        # allowed_dirs_extra: union (append-only) + null safety (Fix 3)
        if 'allowed_dirs_extra' in local:
            base_dirs = set(default_config.get('allowed_dirs_extra', []))
            local_value = local['allowed_dirs_extra']
            if isinstance(local_value, list):
                base_dirs |= set(local_value)
            elif local_value is not None:
                if DEBUG:
                    print(
                        f"WARNING: allowed_dirs_extra expected array, got "
                        f"{type(local_value).__name__}. Ignoring.",
                        file=sys.stderr,
                    )
            default_config['allowed_dirs_extra'] = sorted(base_dirs)

        # known_safe_extra: union (append-only)
        if 'known_safe_extra' in local:
            base_extra = set(default_config.get('known_safe_extra', []))
            local_value = local['known_safe_extra']
            if isinstance(local_value, list):
                base_extra |= set(local_value)
            elif local_value is not None:
                if DEBUG:
                    print(
                        f"WARNING: known_safe_extra expected array, got "
                        f"{type(local_value).__name__}. Ignoring.",
                        file=sys.stderr,
                    )
            default_config['known_safe_extra'] = sorted(base_extra)

        # interpreters_extra: merge (additive only)
        if 'interpreters_extra' in local:
            local_value = local['interpreters_extra']
            if isinstance(local_value, dict):
                base_extra = default_config.get('interpreters_extra', {})
                for k, v in local_value.items():
                    if isinstance(v, dict):
                        base_extra[k] = v
                default_config['interpreters_extra'] = base_extra
            elif local_value is not None:
                if DEBUG:
                    print(
                        f"WARNING: interpreters_extra expected mapping, got "
                        f"{type(local_value).__name__}. Ignoring.",
                        file=sys.stderr,
                    )

    return default_config


def canonicalize_path(path):
    """
    Portable path normalization with symlink resolution (F-006).
    Uses os.path.realpath to resolve symlinks and .. components.
    realpath() internally calls normpath(), so both symlinks and
    lexical components (.., ., //) are handled.
    """
    # Resolve symlinks and normalize (handles . and .., duplicate /)
    resolved = os.path.realpath(path)

    # Ensure the result is in POSIX format (forward slashes)
    return resolved.replace(os.sep, '/')


def phase_s0_null_byte_check(input_str, command):
    """Phase S0: Reject null bytes and empty commands."""
    # Check for literal null bytes (0x00)
    if '\x00' in input_str:
        reject("S0:null_byte")

    # Check for JSON-encoded null (\u0000)
    if '\\u0000' in input_str:
        reject("S0:json_null")

    # Empty command check
    if not command:
        reject("S0:empty_command")


def phase_1_sanitize(input_data, command):
    """Phase 1: Control chars, tool_name validation, Unicode whitespace."""
    # Guard S1: Control characters (0x00-0x1F, 0x7F)
    # Using regex to match any control character
    if re.search(r'[\x00-\x1f\x7f]', command):
        reject("S1:control_chars")

    # Guard S1.5 (F-016): Reject Unicode whitespace characters
    # Python str.split() splits on Unicode whitespace that bash does not recognize,
    # creating parse discrepancies where the hook sees different tokens than bash.
    if re.search(r'[\u0085\u00a0\u2000-\u200b\u2028\u2029\u202f\u205f\u3000\ufeff]', command):
        reject("S1:unicode_whitespace")

    # Guard S2: tool_name must be "Bash"
    tool_name = input_data.get("tool_name", "")
    if tool_name != "Bash":
        reject("S2:tool_name")


def phase_1_5_strip_safe_suffixes(command):
    """Phase 1.5: Strip safe trailing suffixes (2>&1, || true, etc.)."""
    original_command = command
    safe_suffix = ""

    # Regex patterns (unquoted for Python re module)
    re_or_true = re.compile(r'^(.+) \|\| true$')
    re_2_redir1 = re.compile(r'^(.+) 2>&1$')
    re_2_redir_null = re.compile(r'^(.+) 2>/dev/null$')

    # Safe content inside double quotes: no $, backtick, (), backslash
    safe_dq = r'[^$`()\\"]*'
    re_or_echo_dq = re.compile(r'^(.+) \|\| echo "(' + safe_dq + r')"$')
    re_and_echo_dq = re.compile(r'^(.+) && echo "(' + safe_dq + r')"$')

    # Single-quoted: reject only single quotes
    re_or_echo_sq = re.compile(r"^(.+) \|\| echo '([^']*)'$")
    re_and_echo_sq = re.compile(r"^(.+) && echo '([^']*)'$")

    # Iteratively strip suffixes
    suffix_changed = True
    while suffix_changed:
        suffix_changed = False

        # Strip: || true
        m = re_or_true.match(command)
        if m:
            command = m.group(1)
            safe_suffix = " || true" + safe_suffix
            suffix_changed = True
            continue

        # Strip: || echo "literal"
        m = re_or_echo_dq.match(command)
        if m:
            command = m.group(1)
            safe_suffix = f' || echo "{m.group(2)}"' + safe_suffix
            suffix_changed = True
            continue

        # Strip: || echo 'literal'
        m = re_or_echo_sq.match(command)
        if m:
            command = m.group(1)
            safe_suffix = f" || echo '{m.group(2)}'" + safe_suffix
            suffix_changed = True
            continue

        # Strip: && echo "literal"
        m = re_and_echo_dq.match(command)
        if m:
            command = m.group(1)
            safe_suffix = f' && echo "{m.group(2)}"' + safe_suffix
            suffix_changed = True
            continue

        # Strip: && echo 'literal'
        m = re_and_echo_sq.match(command)
        if m:
            command = m.group(1)
            safe_suffix = f" && echo '{m.group(2)}'" + safe_suffix
            suffix_changed = True
            continue

        # Strip: 2>&1
        m = re_2_redir1.match(command)
        if m:
            command = m.group(1)
            safe_suffix = " 2>&1" + safe_suffix
            suffix_changed = True
            continue

        # Strip: 2>/dev/null
        m = re_2_redir_null.match(command)
        if m:
            command = m.group(1)
            safe_suffix = " 2>/dev/null" + safe_suffix
            suffix_changed = True
            continue

    if safe_suffix and DEBUG:
        print(f"SUFFIX_STRIPPED[{safe_suffix}]", file=sys.stderr)

    return command


def phase_2_shell_syntax(command):
    """Phase 2: Reject dangerous shell syntax."""
    # Guard P1: Shell operators
    if re.search(r'[;|&`]', command):
        reject("P1:shell_operators")

    # Guard P2: Redirections and process substitution
    if re.search(r'[><]', command):
        reject("P2:redirections")

    # Guard P3: Command substitution $(...)
    if re.search(r'\$\(', command):
        reject("P3:cmd_substitution")

    # Guard P4 (F-014): Variable/arithmetic expansion
    # Broadened regex: catch $!, $#, $@, $-, $? and all other $X patterns
    if re.search(r'\$[^\s]', command):
        reject("P4:var_expansion")

    # Guard P5: Environment variable assignment
    if re.search(r'^[A-Za-z_][A-Za-z0-9_]*=', command):
        reject("P5:env_assignment")

    # Guard P6: Tilde expansion
    if re.search(r'(^| )~', command):
        reject("P6:tilde_expansion")

    # Guard P7: Glob/brace expansion
    if re.search(r'[*?\[{]', command):
        reject("P7:glob_chars")

    # Guard P8: No-space interpreter (python3scripts/foo.py, bashscripts/run.sh)
    # This catches cases where interpreter and path are concatenated without space
    if re.match(r'^(python3|bash|sh)(scripts/|\.claude/)', command):
        reject("P2:no_space_after_interpreter")

    # Guard P8.5 (F-001): Reject quote/backslash characters in command name position
    # This blocks: "rm", 'bash', $'curl', \rm, r""m
    first_space = command.find(' ')
    cmd_part = command[:first_space] if first_space > 0 else command
    if re.search(r"""['\"\\]""", cmd_part):
        reject("P2:quoted_command_name")


def phase_3_parse_command(command, config):
    """Phase 3: Split into words, identify interpreter."""
    # Split on whitespace (DO NOT use shlex.split - it processes quotes)
    words = command.split()

    if not words:
        reject("P3:empty_words")

    interpreter = words[0]
    script_path = ""

    # Check if interpreter is in known interpreters (case-sensitive)
    # Also check interpreters_extra for user-defined interpreters
    interpreters_list = list(config["interpreters"].keys())
    interpreters_extra = config.get("interpreters_extra", {})
    is_known_interpreter = interpreter in interpreters_list

    # If not in base interpreters, check interpreters_extra
    if not is_known_interpreter and interpreter in interpreters_extra:
        # Merge extra interpreter config into main interpreters for Phase 4 use
        config["interpreters"][interpreter] = interpreters_extra[interpreter]
        is_known_interpreter = True

    if not is_known_interpreter:
        # Check for shell builtins (source, ., exec, eval)
        # These should be rejected as they bypass script containment checks
        if interpreter in ["source", ".", "exec", "eval"]:
            reject("P3:shell_builtin")

        # Direct execution: first word is the script path
        script_path = interpreter

    return words, interpreter, script_path, is_known_interpreter


def phase_4_normalize_flags(words, interpreter, script_path, is_known_interpreter, config):
    """Phase 4: Classify flags, find script path for known interpreters."""
    # Only applies when a known interpreter is used
    if not is_known_interpreter or script_path:
        return script_path

    interp_config = config["interpreters"].get(interpreter, {})
    safe_flags = interp_config.get("safe_flags", [])
    danger_flags = interp_config.get("dangerous_flags", [])
    danger_long_flags = interp_config.get("dangerous_long_flags", [])

    idx = 1
    while idx < len(words):
        word = words[idx]

        if word.startswith("-"):
            # Check for dangerous long flags (F-008: prefix match with =value)
            for dlf in danger_long_flags:
                if word == dlf or word.startswith(dlf + "="):
                    reject("P4:dangerous_flag")

            # Check for dangerous single-char flags (prefix match: -c, -ccode, etc.)
            for flag_char in danger_flags:
                if word == f"-{flag_char}" or word.startswith(f"-{flag_char}"):
                    reject("P4:dangerous_flag")

            # Compound flag decomposition: -xeu -> check x, e, u individually
            # Only for short flags (not --long-flags)
            if len(word) >= 2 and not word.startswith("--"):
                # Step 1: Check dangerous flags first (priority)
                for ch in word[1:]:
                    if ch in danger_flags:
                        reject("P4:dangerous_flag")
                # Step 2: Verify all chars are safe
                all_safe = True
                for ch in word[1:]:
                    if ch not in safe_flags:
                        all_safe = False
                        break
                if all_safe:
                    idx += 1
                    continue

            # Unknown flag - fail closed
            reject("P4:unknown_flag")
        else:
            # Positional argument = script path
            script_path = word
            break

        idx += 1

    return script_path


def phase_5_normalize_path(script_path):
    """Phase 5: Resolve to absolute path."""
    if not script_path:
        reject("P4:no_script_path")

    # Normalize to absolute
    if script_path.startswith('/'):
        abs_path = canonicalize_path(script_path)
    else:
        abs_path = canonicalize_path(os.path.join(PROJECT_DIR, script_path))

    if not abs_path:
        reject("P5:empty_abs_path")

    # Check if the resolved path escapes project directory
    # This catches cases like "scripts/../../etc/passwd"
    project_prefix = PROJECT_DIR + "/"
    if abs_path != PROJECT_DIR and not abs_path.startswith(project_prefix):
        reject("P5:path_traversal_escape")

    return abs_path


def phase_6_project_check(abs_path, is_known_interpreter, config, words):
    """Phase 6: Check PROJECT_DIR containment (+ allowed_dirs_extra).

    Auto-approves only:
      - Known interpreter + script path in PROJECT_DIR or allowed_dirs_extra
      - Direct path execution (words[0] contains '/') in PROJECT_DIR or allowed_dirs_extra
    Plain command names (e.g. 'rm', 'curl') fall through to Phase 7.
    """
    # Only auto-approve interpreters or actual path-based execution
    is_path_execution = "/" in words[0]
    if not is_known_interpreter and not is_path_execution:
        return False  # Plain command name → Phase 7 handles it

    canon_abs = canonicalize_path(abs_path)

    # Check 1: PROJECT_DIR containment
    canon_project = canonicalize_path(PROJECT_DIR)
    project_prefix = canon_project + "/"

    if canon_abs == canon_project or canon_abs.startswith(project_prefix):
        allow()

    # Check 2: allowed_dirs_extra containment
    allowed_dirs_extra = config.get("allowed_dirs_extra", [])
    for extra_dir in allowed_dirs_extra:
        if not extra_dir:
            continue
        canon_extra = canonicalize_path(extra_dir)
        if not canon_extra:
            continue
        extra_prefix = canon_extra + "/"
        if canon_abs == canon_extra or canon_abs.startswith(extra_prefix):
            allow()

    # Path is outside project and allowed_dirs_extra
    if is_known_interpreter:
        reject("P6:not_in_allowed_dir")

    # Non-interpreter path outside project: fall through to Phase 7
    return False


def phase_7b2_subcommand_check(words, config):
    """Phase 7B2: Subcommand evaluation with safe-enumeration (subcommand_rules)
    and legacy deny rules (subcommand_ask)."""
    subcommand_ask = config.get("subcommand_ask", [])
    subcommand_rules = config.get("subcommand_rules", {})

    if not subcommand_ask and not subcommand_rules:
        return  # No rules configured

    # Extract command name (basename)
    cmd_name = os.path.basename(words[0])

    # Only apply subcommand checks if the command is not path-like
    first_word = words[0]
    if "/" in first_word:
        return

    # Extract subcommands and arguments (skip flags)
    # F-002: Track leading flags (flags before first subcommand) for fail-closed
    has_leading_flags = False
    subcommands = []
    all_args = []

    for i in range(1, len(words)):
        word = words[i]
        all_args.append(word)
        if word.startswith("-"):
            if not subcommands:  # Flag before any subcommand
                has_leading_flags = True
        else:
            # F-007: Normalize path-like subcommand arguments
            subcommands.append(os.path.normpath(word))

    # F-002: If leading flags exist and this command has rules, fail closed
    cmd_has_rules = (
        cmd_name in subcommand_rules
        or any(rule.split(":")[0] == cmd_name for rule in subcommand_ask)
    )
    if has_leading_flags and cmd_has_rules:
        reject(f"P7B2:leading_flags:{cmd_name}")

    # --- New: subcommand_rules (safe-enumeration) ---
    if cmd_name in subcommand_rules:
        rules = subcommand_rules[cmd_name]
        allow_list = rules.get("allow", [])
        ask_list = rules.get("ask", [])
        default_action = rules.get("default_action", "ask")

        if not subcommands:
            # No subcommand provided (e.g., bare "git") - allow (shows help)
            return

        # Build the subcommand key for matching
        # Support nested subcommands: "stash:drop" matches subcommands ["stash", "drop"]
        first_sub = subcommands[0]
        compound_key = first_sub
        if len(subcommands) > 1:
            compound_key = first_sub + ":" + subcommands[1]

        # Check ask list first (explicit deny takes priority)
        for ask_entry in ask_list:
            ask_parts = ask_entry.split(":")
            if len(ask_parts) == 1:
                # Simple subcommand match: "push", "clean", etc.
                if first_sub == ask_parts[0]:
                    reject(f"P7B2:subcommand_rules_ask:{cmd_name}:{ask_entry}")
            elif len(ask_parts) == 2:
                # Compound match: "stash:drop", "branch:-D", "checkout:."
                # First part matches subcommand, second part matches next subcommand or flag
                if first_sub == ask_parts[0]:
                    second = ask_parts[1]
                    if second.startswith("-"):
                        # Flag check: look for flag in all_args
                        if second in all_args:
                            reject(f"P7B2:subcommand_rules_ask:{cmd_name}:{ask_entry}")
                    else:
                        # Subcommand check: match second positional subcommand
                        normalized_second = os.path.normpath(second)
                        if len(subcommands) > 1 and subcommands[1] == normalized_second:
                            reject(f"P7B2:subcommand_rules_ask:{cmd_name}:{ask_entry}")

        # Check allow list
        for allow_entry in allow_list:
            allow_parts = allow_entry.split(":")
            if len(allow_parts) == 1:
                if first_sub == allow_parts[0]:
                    return  # Allowed, continue to path checks
            elif len(allow_parts) == 2:
                if first_sub == allow_parts[0]:
                    second = allow_parts[1]
                    if second.startswith("-"):
                        if second in all_args:
                            return
                    else:
                        normalized_second = os.path.normpath(second)
                        if len(subcommands) > 1 and subcommands[1] == normalized_second:
                            return

        # Not in allow or ask lists - apply default_action
        if default_action == "ask":
            reject(f"P7B2:subcommand_rules_default:{cmd_name}:{first_sub}")
        # default_action == "allow" would fall through (allow)
        return

    # --- Legacy: subcommand_ask (danger-enumeration, backward compat) ---
    for rule in subcommand_ask:
        parts = rule.split(":")

        if len(parts) < 2:
            continue

        rule_cmd = parts[0]
        rule_subs = parts[1:]

        if cmd_name != rule_cmd:
            continue

        # Match subcommands (F-009: separate sub_idx to avoid index confusion)
        matched = True
        sub_idx = 0
        for rule_sub in rule_subs:
            if rule_sub.startswith("-"):
                if rule_sub not in all_args:
                    matched = False
                    break
            else:
                normalized_rule = os.path.normpath(rule_sub)
                if sub_idx >= len(subcommands) or subcommands[sub_idx] != normalized_rule:
                    matched = False
                    break
                sub_idx += 1

        if matched:
            reject(f"P7B2:subcommand_ask:{rule}")


def phase_7_general_command(words, config):
    """Phase 7: ALWAYS_ASK + path containment for non-interpreter commands."""
    # Step 7A: Extract command name
    cmd_name = os.path.basename(words[0])

    if DEBUG:
        print(f"P7A:cmd={cmd_name}", file=sys.stderr)

    # Step 7A2: Reject case-mismatched interpreter names
    # (e.g., PYTHON3, Python3, BASH, Bash should be rejected)
    cmd_lower = cmd_name.lower()
    interpreters_list = list(config["interpreters"].keys())
    for interp in interpreters_list:
        if cmd_lower == interp and cmd_name != interp:
            reject(f"P7A2:case_mismatch:{cmd_name}")

    # Step 7B: Check ALWAYS_ASK list (F-013: case-insensitive matching)
    always_ask = config.get("always_ask", [])
    always_ask_lower = {a.lower() for a in always_ask}
    if cmd_name.lower() in always_ask_lower:
        reject(f"P7B:always_ask:{cmd_name}")

    # Step 7B2: Check subcommand deny rules (NEW PHASE)
    phase_7b2_subcommand_check(words, config)

    # Step 7B3: deny-by-default with known_safe check
    # If command is NOT in known_safe + known_safe_extra, return ask
    known_safe = set(config.get("known_safe", []))
    known_safe_extra = set(config.get("known_safe_extra", []))
    all_known_safe = known_safe | known_safe_extra
    if cmd_name not in all_known_safe:
        if DEBUG:
            print(f"P7B3:deny_by_default:{cmd_name}", file=sys.stderr)
        reject(f"P7B3:not_known_safe:{cmd_name}")

    # Step 7C: Collect path candidates (ALL non-flag positional args)
    # Changed from "/" heuristic to all-argument path candidacy.
    # Non-path arguments (e.g., "status" in "git status") resolve to
    # PROJECT_DIR/status which passes containment (harmless, no false rejection).
    # NOTE: Flag arguments that are paths (e.g., git -C /path) are intentionally
    # checked for containment. This is correct behavior (F-012).
    path_args = []
    past_dd = False  # past "--" marker

    # Check words[0] first (for direct execution, this is the script path)
    first_word = words[0]
    if "/" in first_word:
        path_args.append(first_word)

    for i in range(1, len(words)):
        word = words[i]

        # End-of-options marker
        if word == "--" and not past_dd:
            past_dd = True
            continue

        # Skip flags (unless past --)
        if word.startswith("-") and not past_dd:
            continue

        # Strip surrounding quotes
        word_stripped = word
        if len(word_stripped) >= 2:
            if (word_stripped[0] == '"' and word_stripped[-1] == '"') or \
               (word_stripped[0] == "'" and word_stripped[-1] == "'"):
                word_stripped = word_stripped[1:-1]

        # Detect URLs (contains ://)
        if "://" in word_stripped:
            reject(f"P7C:url_detected:{word_stripped}")

        # ALL non-flag arguments are path candidates (no "/" filter)
        path_args.append(word_stripped)

    if DEBUG:
        print(f"P7C:paths={' '.join(path_args) if path_args else 'none'}", file=sys.stderr)

    # Step 7D: Check path containment
    if not path_args:
        # No positional arguments at all - allow (command with only flags)
        if DEBUG:
            print("P7D:allow:no_args", file=sys.stderr)
        allow()

    # Check each path for project containment
    allowed_dirs_extra = config.get("allowed_dirs_extra", [])

    for idx, p7_path in enumerate(path_args):
        # Resolve to absolute
        if p7_path.startswith('/'):
            p7_abs = canonicalize_path(p7_path)
        else:
            p7_abs = canonicalize_path(os.path.join(PROJECT_DIR, p7_path))

        if not p7_abs:
            reject("P7D:empty_abs")

        # Check containment against project directory
        p7_contained = False

        project_prefix = PROJECT_DIR + "/"
        if p7_abs == PROJECT_DIR or p7_abs.startswith(project_prefix):
            p7_contained = True

        # Check containment against extra allowed directories
        if not p7_contained and allowed_dirs_extra:
            for extra_dir in allowed_dirs_extra:
                if not extra_dir:
                    continue

                extra_resolved = canonicalize_path(extra_dir)
                if not extra_resolved:
                    continue

                extra_prefix = extra_resolved + "/"
                if p7_abs == extra_resolved or p7_abs.startswith(extra_prefix):
                    p7_contained = True
                    break

        if not p7_contained:
            if DEBUG:
                print(f"P7D:reject:outside={p7_abs}", file=sys.stderr)
            reject(f"P7D:outside_project:{p7_abs}")

    # All paths contained
    if DEBUG:
        print("P7D:allow:all_contained", file=sys.stderr)
    allow()


def validate_single_command(command, config):
    """Phase 3-7を1コマンドに対して実行。
    Returns: ("allow", reason) or ("reject", reason)
    """
    try:
        words, interpreter, script_path, is_known_interpreter = phase_3_parse_command(command, config)
        script_path = phase_4_normalize_flags(words, interpreter, script_path, is_known_interpreter, config)
        abs_path = phase_5_normalize_path(script_path)
        phase_6_project_check(abs_path, is_known_interpreter, config, words)
        phase_7_general_command(words, config)
        return ("reject", "no_rule_matched")  # fail-closed
    except AllowException:
        return ("allow", "phase_passed")
    except RejectException as e:
        return ("reject", e.reason)


def output_allow():
    """Output allow decision and exit."""
    print(json.dumps({
        "hookSpecificOutput": {
            "hookEventName": "PermissionRequest",
            "decision": {"behavior": "allow"}
        }
    }))
    sys.exit(0)


def output_reject(reason):
    """Output reject decision and exit."""
    if DEBUG:
        print(f"REJECT[{reason}]", file=sys.stderr)
    sys.exit(0)


def main():
    """Main entry point."""
    input_str = sys.stdin.read()
    try:
        config = load_config()
    except RejectException as e:
        output_reject(e.reason)
        return

    try:
        input_data = json.loads(input_str)
    except json.JSONDecodeError:
        output_reject("json_parse_error")
        return

    command = input_data.get("tool_input", {}).get("command", "")

    # Pre-validation (Phase S0, 1, 1.5, 2) — 複合コマンド分割前
    try:
        phase_s0_null_byte_check(input_str, command)
        phase_1_sanitize(input_data, command)
        command = phase_1_5_strip_safe_suffixes(command)
        phase_2_shell_syntax(command)
    except RejectException as e:
        output_reject(e.reason)
        return

    # Phase 3-7 (validate_single_command経由)
    decision, reason = validate_single_command(command, config)
    if decision == "allow":
        output_allow()
    else:
        output_reject(reason)


if __name__ == "__main__":
    main()
