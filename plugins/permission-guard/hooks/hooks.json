{
  "description": "8-phase Bash command permission validation. Auto-approves safe commands, blocks dangerous patterns.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/boot",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
