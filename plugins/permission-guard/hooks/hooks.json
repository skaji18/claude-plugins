{
  "description": "8-phase Bash command permission validation + file access guard. Auto-approves safe commands, blocks dangerous patterns, guards file access paths.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/boot",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/boot-file",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
